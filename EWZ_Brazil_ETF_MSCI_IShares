import pandas as pd
import yfinance as yf
import ssl
import urllib.request
import re

# --- BYPASS SSL CERTIFICATE ISSUES ---
ssl._create_default_https_context = ssl._create_unverified_context

def get_brazil_tickers():
    """
    Improved scrape for the Bovespa (Brazil) index.
    Searches all tables for Brazilian stock patterns.
    """
    # URL for the Bovespa Index (using percent encoding for 'Í')
    url = "https://en.wikipedia.org/wiki/%C3%8Dndice_Bovespa"
    req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
    
    try:
        with urllib.request.urlopen(req) as response:
            tables = pd.read_html(response)
            
            for df in tables:
                # Convert the whole table to string to search for stock patterns (e.g., VALE3, ITUB4)
                # Brazilian tickers are usually 4 letters + 1 digit
                table_str = df.to_string()
                if re.search(r'[A-Z]{4}[3-6]', table_str):
                    # Identify the column that looks like tickers
                    for col in df.columns:
                        sample = df[col].astype(str).str.strip().iloc[0:5]
                        if any(re.match(r'^[A-Z]{4}[3-6]$', s) for s in sample):
                            tickers = df[col].astype(str).str.strip().unique()
                            # Clean and format
                            return [f"{t}.SA" for t in tickers if re.match(r'^[A-Z]{4}[3-6]$', t)]
            
            print("Pattern matching failed to find a ticker table.")
            return []
            
    except Exception as e:
        print(f"Scrape Error: {e}")
        return []

# --- PHASE 1: GET TICKERS & VALIDATE MARKET CAPS ---
print("Phase 1: Finding Tickers on Wikipedia...")
tickers = get_brazil_tickers()

if not tickers:
    # If the scrape fails, we use a manual "Seed List" of the top 30 to ensure the script runs
    print("Scrape failed. Using manual Top-30 Ticker List for Brazil...")
    tickers = [
        "VALE3.SA", "PETR4.SA", "ITUB4.SA", "PETR3.SA", "BBDC4.SA", "ABEV3.SA", "BBAS3.SA", 
        "WEGE3.SA", "ITSA4.SA", "B3SA3.SA", "RENT3.SA", "LREN3.SA", "EQTL3.SA", "PRIO3.SA", 
        "RDOR3.SA", "RAIL3.SA", "VIVT3.SA", "GGBR4.SA", "SUZB3.SA", "CPLE6.SA", "CSAN3.SA", 
        "HAPV3.SA", "VBBR3.SA", "SBSP3.SA", "ELET3.SA", "ELET6.SA", "RADL3.SA", "TIMS3.SA", 
        "UGPA3.SA", "CMIG4.SA"
    ]

cap_data = []
for t in tickers:
    try:
        stock = yf.Ticker(t)
        mcap = stock.info.get('marketCap', 0)
        if mcap > 0:
            cap_data.append({'Ticker': t, 'MarketCap': mcap})
            print(f"Added: {t} | {mcap:,.0f} BRL")
    except:
        continue

if not cap_data:
    print("CRITICAL: Could not fetch Market Cap data.")
    exit()

# Sort by Market Cap
df_caps = pd.DataFrame(cap_data).sort_values('MarketCap', ascending=False)
ordered_tickers = df_caps['Ticker'].tolist()

# --- PHASE 2: DOWNLOAD DATA ---
print(f"\nPhase 2: Downloading Daily Data for {len(ordered_tickers)} stocks...")
data = yf.download(ordered_tickers, start="1976-01-01", end="2026-03-19", auto_adjust=True)

if isinstance(data.columns, pd.MultiIndex):
    close_data = data['Close']
else:
    close_data = data

# --- PHASE 3: EXPORT ---
df_wide = close_data[ordered_tickers].transpose()
df_wide.columns = pd.to_datetime(df_wide.columns).strftime('%Y-%m-%d')

file_name = f"Brazil_MarketCap_Sorted_Full_{len(ordered_tickers)}.csv"
df_wide.to_csv(file_name)

print("-" * 30)
print(f"Success! File saved as: {file_name}")
